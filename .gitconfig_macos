[user]
  signingkey = key::ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIEVbk4ZqXm38ztBfkXIucdu7bBvzgUm/zhkFNg+aOAst

[gpg]
  format = ssh

[gpg "ssh"]
  program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"

[credential]
  helper = osxkeychain

# Rewrite GitHub URLs to use SSH. Covers the `https://` form (so
# `git clone https://github.com/foo/bar` transparently fetches/pushes over SSH
# without needing to remember to type the git@ form), and the obsolete `git://`
# protocol (deprecated by GitHub in 2022; kept here so any old script using it
# gets auto-redirected to SSH rather than failing with a connection-refused on
# port 9418).
#
# Lives in this Mac-only file because the SSH key behind this is held by
# 1Password — on hosts without 1Password (e.g. plain Codespaces) there's no
# key to github.com, so a global https→ssh rewrite would break every
# `git clone https://github.com/...` with "Host key verification failed".
# Sibling .gitconfig_linux / .gitconfig_windows files carry the same rewrites
# for hosts where 1Password IS installed; bootstrap picks the right one by OS
# and gates Linux on the presence of /opt/1Password/op-ssh-sign.
[url "git@github.com:"]
  insteadOf = https://github.com/
  insteadOf = "git://github.com/"

# Same rewriting for gists.
[url "git@gist.github.com:"]
  insteadOf = "git://gist.github.com/"
