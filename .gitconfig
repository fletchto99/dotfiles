[core]
  excludesfile = ~/.gitignore_global
  # FSEvents-based file system monitor — speeds up `git status` 5-10x on large repos.
  # Requires git 2.37+. Free on macOS; ignored elsewhere if unsupported.
  fsmonitor = true
  untrackedCache = true
  # Editor: VS Code Insiders. Works on every platform that has the Insiders build
  # installed (macOS / Linux / Windows / WSL). The one realistic gap is plain
  # GitHub Codespaces, where only `code` is in PATH by default; override locally
  # there with `git config --global core.editor "code --wait"` if needed.
  editor = code-insiders --wait

[user]
  name = Matt Langlois
  email = fletchto99@gmail.com

[init]
  defaultBranch = main

[commit]
  gpgsign = true
  # Show the diff in the commit-message editor so you can sanity-check
  # what you're committing while writing the message.
  verbose = true

[tag]
  # If commits sign, tags should too — they're what releases pin to.
  gpgsign = true

[github]
  user = fletchto99
  shelluser = matt

[protocol]
  version = 2

[fetch]
  prune = true
  # Maintain a commit-graph file that speeds up log/blame/walks on large repos.
  writeCommitGraph = true

[push]
  default = simple
  autoSetupRemote = true
  # Push annotated tags reachable from pushed commits without needing --tags.
  followTags = true

[pull]
  rebase = true

[rerere]
  # Reuse recorded resolution — once you resolve a conflict, git remembers it
  # and auto-applies the same resolution next time. Big rebase time-saver.
  enabled = true

[branch]
  # `git branch` lists most-recently-committed branches first, not alphabetical.
  sort = -committerdate

[help]
  # When you typo `git puhs`, git asks "did you mean push?" instead of either
  # running puhs silently or auto-correcting after a tiny delay.
  autocorrect = prompt

[color]
  ui = true

[color "branch"]
  current = magenta
  remote = cyan

[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red reverse
  new = green reverse
  whitespace = white reverse

[color "status"]
  added = green
  changed = cyan
  untracked = blue bold
  branch = magenta

[diff]
  renames = copies
  # Histogram produces more readable diffs than the default `myers`, especially
  # for code with lots of structural changes.
  algorithm = histogram
  # Color lines that moved (vs. added/deleted) distinctly — huge help when
  # reviewing refactors.
  colorMoved = zebra
  # Treat indentation-only differences as moves rather than separate add/delete.
  colorMovedWS = allow-indentation-change
  tool = vscode

[difftool]
  prompt = false

[difftool "vscode"]
  cmd = code-insiders --wait --diff $LOCAL $REMOTE

[mergetool]
  prompt = false

[mergetool "vscode"]
  # VS Code's native 3-way merge UI (--merge) rather than --diff, which would
  # only show LOCAL vs REMOTE without letting you edit MERGED.
  cmd = code-insiders --wait --merge $REMOTE $LOCAL $BASE $MERGED

[merge]
  # zdiff3 shows the common-ancestor version between ||||||| markers alongside
  # both sides — makes conflict resolution noticeably faster than the default
  # `merge` style. Requires git 2.35+.
  conflictStyle = zdiff3
  tool = vscode

[alias]
  # Lol for when I forget
  aliases = config --get-regexp alias

  # List remotes
  rv = remote -v

  # Patch mode for adding so I don't add random stuff
  addp = add --patch

  # Shortcut to diff tool
  dt = difftool

  # Shortcut to diff tool on staged files
  dts = difftool --staged

  # Show the diff between the latest commit and the current state
  dl = !"git diff-index --quiet HEAD -- || clear; git --no-pager diff --patch-with-stat"

  # `git di $number` shows the diff between the state `$number` revisions ago and the current state
  di = !"d() { git diff --patch-with-stat HEAD~$1; }; git diff-index --quiet HEAD -- || clear; d"

  # Find branches containing commit - lets track down what broke things!!
  fb = "!f() { git branch -a --contains $1; }; f"

  # Recently committed to branches
  recent = for-each-ref --count=30 --sort=-committerdate --format="%(committerdate:relative)%09%(refname:short)" refs/heads

  # Pretty logs
  lg = !"git lg1"
  lg1 = !"git lg1-specific --all"
  lg2 = !"git lg2-specific --all"
  lg3 = !"git lg3-specific --all"

  # Pretty log commands
  lg1-specific = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(auto)%d%C(reset)'
  lg2-specific = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(auto)%d%C(reset)%n''          %C(white)%s%C(reset) %C(dim white)- %an%C(reset)'
  lg3-specific = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset) %C(bold cyan)(committed: %cD)%C(reset) %C(auto)%d%C(reset)%n''          %C(white)%s%C(reset)%n''          %C(dim white)- %an <%ae> %C(reset) %C(dim white)(committer: %cn <%ce>)%C(reset)'

# Rewrite GitHub URLs to use SSH everywhere. Covers the `https://` form (so
# `git clone https://github.com/foo/bar` transparently fetches/pushes over SSH
# without needing to remember to type the git@ form), and the obsolete `git://`
# protocol (deprecated by GitHub in 2022; kept here so any old script using it
# gets auto-redirected to SSH rather than failing with a connection-refused on
# port 9418).
[url "git@github.com:"]
  insteadOf = https://github.com/
  insteadOf = "git://github.com/"

# Same rewriting for gists.
[url "git@gist.github.com:"]
  insteadOf = "git://gist.github.com/"

[includeIf "gitdir:/Users/"]
  path = .gitconfig_macos

# Both an https and an ssh variant are needed because `hasconfig:remote.*.url`
# matches against the URL as stored in .git/config (which is whatever you typed
# at clone time), not the rewritten form that insteadOf produces at fetch/push
# time. gitconfig has no boolean-OR syntax for conditional includes, so each
# stored URL form gets its own stanza pointing at the same file.
[includeIf "hasconfig:remote.*.url:https://github.com/github/**"]
  path = .gitconfig_work

[includeIf "hasconfig:remote.*.url:git@github.com:github/**"]
  path = .gitconfig_work
