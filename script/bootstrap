#!/usr/bin/env bash

# ─── Helpers ────────────────────────────────────────────────────────────────

# Compare two dotted version strings.
# Returns 0 if equal, 1 if v1 > v2, 2 if v1 < v2.
vercomp () {
    if [[ $1 == $2 ]]; then
        return 0
    fi
    local IFS=.
    local i ver1=($1) ver2=($2)
    for ((i=${#ver1[@]}; i<${#ver2[@]}; i++)); do
        ver1[i]=0
    done
    for ((i=0; i<${#ver1[@]}; i++)); do
        if [[ -z ${ver2[i]:-} ]]; then
            ver2[i]=0
        fi
        if ((10#${ver1[i]} > 10#${ver2[i]})); then
            return 1
        fi
        if ((10#${ver1[i]} < 10#${ver2[i]})); then
            return 2
        fi
    done
    return 0
}

# Safely create a symlink from $1 to $2:
#   - If $2 is already a symlink (whether or not it points where we want),
#     remove and recreate. No backup — symlinks aren't user data.
#   - If $2 is a real file/dir, copy it to ~/dotfiles_old/<relative path>/
#     before replacing. Preserves user-edited dotfiles on first bootstrap.
#   - If $2 doesn't exist, just create the link.
# This is the pattern that makes re-running bootstrap idempotent: the old
# loop pattern (`if [ -f ~/file ]; then cp ...; fi`) followed symlinks and
# re-backed-up the dotfiles content on every run, eventually overwriting
# the original user file in the "backup" directory.
safe_link() {
    local src="$1"
    local dest="$2"
    local backup="$HOME/dotfiles_old/${dest#$HOME/}"

    if [ -L "$dest" ]; then
        rm -f "$dest"
    elif [ -e "$dest" ]; then
        mkdir -p "$(dirname "$backup")"
        cp -RL "$dest" "$backup"
        rm -rf "$dest"
    fi

    ln -s "$src" "$dest"
}

# Link every file directly under $1 into $2 (used for .ssh/, .copilot/).
# Skips subdirectories — only top-level files in the source directory.
link_directory_contents() {
    local src_dir="$1"
    local dest_dir="$2"
    mkdir -p "$dest_dir"
    for src in "$src_dir"/*; do
        [ -f "$src" ] || continue
        safe_link "$src" "$dest_dir/$(basename "$src")"
    done
}

BOOTSTRAP_DIR="$(cd "$(dirname "$0")" && pwd)"

# ─── Clone dotfiles if not already present ──────────────────────────────────

if [ -d ~/.dotfiles ]; then
    echo "[dotfiles] ~/.dotfiles already exists — make sure to git pull to ensure it's up to date"
else
    git clone https://github.com/fletchto99/dotfiles.git ~/.dotfiles
fi

# ─── Linux: ensure a modern git ─────────────────────────────────────────────

# Recent Ubuntu LTS releases (22.04 ships 2.34) still benefit; 24.04+ ships
# 2.43 and the vercomp check will short-circuit. Guarded against re-runs.
if [[ "$OSTYPE" == "linux-gnu"* ]]; then
    vercomp "$(git --version | sed 's/[^0-9\.]*//g')" "2.36.0"
    if [[ $? == 2 ]]; then
        if [ -d ~/.core-git ]; then
            echo "[dotfiles] ~/.core-git already present — skipping git-from-source build"
        else
            echo "[dotfiles] Installing latest git from source"
            (
                git clone https://github.com/git/git ~/.core-git &&
                cd ~/.core-git &&
                sudo apt-get update &&
                sudo apt-get install -y git gcc make libssl-dev libcurl4-openssl-dev \
                                    libexpat-dev tcl tk gettext git-email zlib1g-dev &&
                printf '%s\n' prefix=/usr gitexecdir=/usr/lib/git-core NO_TCLTK=1 >>config.mak &&
                sudo make -j8 && sudo make -j8 install
            )
        fi
    fi
fi

# ─── Homebrew (macOS) / apt zsh (Linux) ─────────────────────────────────────

if [[ "$OSTYPE" != "linux-gnu"* ]]; then
    if ! command -v brew >/dev/null 2>&1; then
        read -p "[dotfiles] Do you wish to install homebrew? " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
            brew update
            brew upgrade
        fi
    else
        echo "[dotfiles] Homebrew already installed"
    fi

    read -p "[dotfiles] Do you wish to install/sync Brewfile contents? " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        brew bundle --file=~/.dotfiles/Brewfile
        # `brew autoupdate start` errors loudly if already running. Check first.
        if ! brew autoupdate status 2>&1 | grep -q "installed and running"; then
            brew autoupdate start
        fi
        echo "[dotfiles] Cleaning up installers..."
        brew cleanup
    fi
else
    if ! command -v zsh >/dev/null 2>&1; then
        echo "[dotfiles] Installing ZSH"
        sudo apt install -o Dpkg::Options::="--force-confold" --force-yes -y zsh
        sudo chsh -s "$(command -v zsh)"
    else
        echo "[dotfiles] ZSH already installed"
    fi
fi

# ─── iTerm2 setup (macOS) ───────────────────────────────────────────────────

if [ -d "/Applications/iTerm.app/" ]; then
    read -p "[dotfiles] Do you wish to setup iTerm configs? " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        safe_link ~/.dotfiles/.iterm2 ~/.iterm2
        defaults write com.googlecode.iterm2.plist LoadPrefsFromCustomFolder -bool true
        defaults write com.googlecode.iterm2.plist PrefsCustomFolder -string "~/.iterm2"
        # Set login shell to the current zsh (works on both Apple Silicon /opt/homebrew/bin/zsh
        # and Intel /usr/local/bin/zsh; previously hardcoded the Intel path and broke on M-series).
        sudo dscl . -create "/Users/$USER" UserShell "$(command -v zsh)"
    fi
else
    echo "[dotfiles] iTerm not installed, skipping iTerm setup!"
fi

# ─── Alfred 5 setup (macOS) ─────────────────────────────────────────────────

if [ -d "/Applications/Alfred 5.app/" ]; then
    read -p "[dotfiles] Do you wish to setup alfred 5 configs? " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        safe_link ~/.dotfiles/.alfred ~/.alfred
    fi
else
    echo "[dotfiles] Alfred not installed, skipping alfred setup!"
fi

# ─── Oh My Zsh ──────────────────────────────────────────────────────────────

if [ -d ~/.oh-my-zsh ]; then
    echo "[dotfiles] Oh My Zsh already installed"
else
    if [[ "$OSTYPE" != "linux-gnu"* ]]; then
        read -p "[dotfiles] Do you wish to install Oh-My-ZSH? " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            /bin/bash -c "$(curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
        fi
    else
        echo "[dotfiles] Installing oh my zsh"
        sh -c "$(curl -fsSL https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
    fi
fi

# ─── Link dotfiles ──────────────────────────────────────────────────────────

# Collect top-level dotfiles to symlink. Directories handled separately (.ssh, .copilot, etc.)
files=()
while IFS=  read -r -d $'\0'; do
    files+=("$(basename "$REPLY")")
done < <(find ~/.dotfiles -maxdepth 1 -name ".*" -type f -print0)

link_all_dotfiles() {
    echo "[dotfiles] Linking dotfiles (${files[*]})"
    for file in "${files[@]}"; do
        safe_link "$HOME/.dotfiles/$file" "$HOME/$file"
    done

    # .ssh and .copilot: link individual files, NOT the whole directory.
    # .ssh contains machine-local keys (id_*, known_hosts) that must not be
    # clobbered by linking the parent. .copilot contains Copilot CLI runtime
    # state (session-state/, plugins/, MCP configs) that's machine-local.
    [ -d ~/.dotfiles/.ssh ] && link_directory_contents ~/.dotfiles/.ssh ~/.ssh
    [ -d ~/.dotfiles/.copilot ] && link_directory_contents ~/.dotfiles/.copilot ~/.copilot
}

if [[ "$OSTYPE" != "linux-gnu"* ]]; then
    read -p "[dotfiles] Do you wish to link your dotfiles? (existing files will be backed up to ~/dotfiles_old) " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        link_all_dotfiles
    fi
else
    link_all_dotfiles
fi

# ─── Custom oh-my-zsh plugins ───────────────────────────────────────────────

# Cloned on both macOS and Linux (OMZ is installed on both). Idempotent — each
# clone is guarded so re-running bootstrap on an existing setup is a no-op.
OMZ_PLUGINS_DIR="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins"
echo "[dotfiles] Setting up custom oh-my-zsh plugins"

clone_plugin() {
    local name="$1"
    local url="$2"
    if [ ! -d "$OMZ_PLUGINS_DIR/$name" ]; then
        git clone --depth=1 "$url" "$OMZ_PLUGINS_DIR/$name"
    fi
}

clone_plugin zsh-autosuggestions      https://github.com/zsh-users/zsh-autosuggestions
# zsh-syntax-highlighting must be the LAST entry in .zshrc's plugins=(...) —
# it hooks the command-line preexec and gets confused if other plugins load after it.
clone_plugin zsh-syntax-highlighting  https://github.com/zsh-users/zsh-syntax-highlighting.git

echo "[dotfiles] Finished setting up dotfiles..."
