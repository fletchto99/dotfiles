#!/usr/bin/env bash

# Create a new directory and enter it
function mkd() {
  mkdir -p "$@" && cd "$_";
}

# Determine size of a file or total size of a directory
function fs() {
  if du -b /dev/null > /dev/null 2>&1; then
    local arg=-sbh;
  else
    local arg=-sh;
  fi
  if [[ -n "$@" ]]; then
    du $arg -- "$@";
  else
    du $arg .[^.]* ./*;
  fi;
}

# Start an HTTP server from a directory, optionally specifying the port
function server() {
  local port="${1:-8000}";
  sleep 1 && open "http://localhost:${port}/" &
  # Python 3's http.server replaces the (Python-2-only) SimpleHTTPServer used in the older
  # version of this function. --bind 127.0.0.1 keeps the server local rather than binding to all
  # interfaces; drop that flag if you need LAN access.
  python3 -m http.server --bind 127.0.0.1 "${port}";
}

# Run `dig` and display the most useful info
function digga() {
  dig +nocmd "$1" any +multiline +noall +answer;
}

# Show all the names (CNs and SANs) listed in the SSL certificate
# for a given domain
function certinfo() {
  if [ -z "${1}" ]; then
    echo "ERROR: No domain specified.";
    return 1;
  fi;

  local domain="${1}";
  echo "Testing ${domain}…";
  echo ""; # newline

  local tmp=$(echo -e "GET / HTTP/1.0\nEOT" \
    | openssl s_client -connect "${domain}:443" -servername "${domain}" 2>&1);

  if [[ "${tmp}" = *"-----BEGIN CERTIFICATE-----"* ]]; then
    local certText=$(echo "${tmp}" \
      | openssl x509 -text -certopt "no_aux, no_header, no_issuer, no_pubkey, \
      no_serial, no_sigdump, no_signame, no_validity, no_version");
    echo "Common Name:";
    echo ""; # newline
    echo "${certText}" | grep "Subject:" | sed -e "s/^.*CN=//" | sed -e "s/\/emailAddress=.*//";
    echo ""; # newline
    echo "Subject Alternative Name(s):";
    echo ""; # newline
    echo "${certText}" | grep -A 1 "Subject Alternative Name:" \
      | sed -e "2s/DNS://g" -e "s/ //g" | tr "," "\n" | tail -n +2;
    return 0;
  else
    echo "ERROR: Certificate not found.";
    return 1;
  fi;
}

# Find stale transitive Homebrew dependencies that `brew autoremove` misses.
# These are formulae that:
#   1. are currently leaves (nothing installed depends on them)
#   2. were originally installed as a dependency (not via `brew install`)
#   3. whose parent formula's current version no longer requires them
# autoremove sometimes leaves these behind when a parent's deps shift between
# versions. Run periodically; safe to `brew uninstall` everything this lists.
function brew-stale-deps() {
  local f short receipt on_req as_dep
  # `setopt -s null_glob` makes zsh return empty for no-match globs instead of
  # erroring; bash uses `shopt -s nullglob`. Local to the function via subshell.
  (
    setopt null_glob 2>/dev/null || shopt -s nullglob 2>/dev/null
    brew leaves | while IFS= read -r f; do
      # Third-party tap formulae appear as `tap/name` in `brew leaves`, but the
      # Cellar path uses only the basename. Strip everything before the last `/`.
      short="${f##*/}"
      for receipt in /opt/homebrew/Cellar/"$short"/*/INSTALL_RECEIPT.json; do
        [ -e "$receipt" ] || continue
        on_req=$(python3 -c "import json; print(json.load(open('$receipt')).get('installed_on_request'))" 2>/dev/null)
        as_dep=$(python3 -c "import json; print(json.load(open('$receipt')).get('installed_as_dependency'))" 2>/dev/null)
        if [ "$on_req" = "False" ] && [ "$as_dep" = "True" ]; then
          echo "$f"
        fi
        break  # one receipt per formula is enough
      done
    done
  )
}
